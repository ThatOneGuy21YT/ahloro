# ── dashboard.py (Railway) ────────────────────────────────────────────────────
# PostgreSQL connection string
# Internal (same Railway project):  postgresql://postgres:<pass>@postgres.railway.internal:5432/railway
# External (local dev):             postgresql://doorsense:<pass>@localhost/doorsense
DATABASE_URL=postgresql://doorsense:yourpassword@postgres.railway.internal/doorsense

# Shared secret — must match API_KEY in poller .env
# Generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-to-a-long-random-string

# HTTP port (Railway sets this automatically)
PORT=8765

# Bind address — set to 127.0.0.1 when running behind a Cloudflare Tunnel or
# reverse proxy so the port is unreachable from the internet directly
# BIND_HOST=127.0.0.1

# Browser password — enables HTTP Basic Auth on all browser-facing endpoints
# (dashboard page, SSE stream, device list, byte-offset config)
# BROWSER_PASSWORD=change-me

# TLS — paths to PEM cert and key files; enables HTTPS on the built-in server
# Not needed when TLS is handled upstream (Cloudflare Tunnel, Caddy, nginx)
# CERT_FILE=/etc/ssl/doorsense/cert.pem
# KEY_FILE=/etc/ssl/doorsense/key.pem

# ── poller.py (local machine) ─────────────────────────────────────────────────
# Full public URL of the deployed dashboard
DASHBOARD_URL=https://your-app.railway.app

# Shared secret — must match API_KEY in dashboard .env
# API_KEY=change-me-to-a-long-random-string

# Gateway credentials (defaults shown)
# GW_HOST=10.8.8.8
# GW_EMAIL=admin
# GW_PASS=
# SIOT_USER=siot
# SIOT_PASS=dfrobot
