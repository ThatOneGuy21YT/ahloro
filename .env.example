# ── dashboard.py (Railway) ────────────────────────────────────────────────────
# PostgreSQL connection string
# Internal (same Railway project):  postgresql://postgres:<pass>@postgres.railway.internal:5432/railway
# External (local dev):             postgresql://doorsense:<pass>@localhost/doorsense
DATABASE_URL=postgresql://doorsense:yourpassword@postgres.railway.internal/doorsense

# Shared secret — must match API_KEY in poller .env
# Generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-to-a-long-random-string

# HTTP port (Railway sets this automatically)
PORT=8765

# Bind address — set to 127.0.0.1 when running behind a Cloudflare Tunnel or
# reverse proxy so the port is unreachable from the internet directly
# BIND_HOST=127.0.0.1

# Browser password — enables HTTP Basic Auth on all browser-facing endpoints
# (dashboard page, SSE stream, device list, byte-offset config)
# BROWSER_PASSWORD=change-me

# ── Google OAuth (optional — replaces BROWSER_PASSWORD for browser logins) ────
# When GOOGLE_CLIENT_ID is set, all browser requests require a Google session
# instead of Basic Auth. BROWSER_PASSWORD is ignored when OAuth is active.
#
# Set up credentials at https://console.cloud.google.com/apis/credentials
#   1. Create an OAuth 2.0 Client ID (Web application)
#   2. Add OAUTH_REDIRECT_URI to "Authorised redirect URIs"
#
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# OAUTH_REDIRECT_URI=https://your-domain.example.com/auth/callback
#
# Comma-separated allowlist — leave empty to allow any Google account
# GOOGLE_ALLOWED_EMAILS=alice@example.com,bob@example.com

# TLS — paths to PEM cert and key files; enables HTTPS on the built-in server
# Not needed when TLS is handled upstream (Cloudflare Tunnel, Caddy, nginx)
# CERT_FILE=/etc/ssl/doorsense/cert.pem
# KEY_FILE=/etc/ssl/doorsense/key.pem

# ── poller.py — DFRobot gateway (local machine) ───────────────────────────────
# Full public URL of the deployed dashboard
DASHBOARD_URL=https://your-app.example.com

# Shared secret — must match API_KEY in dashboard .env
# API_KEY=change-me-to-a-long-random-string

# This poller's identity (used to separate queues on the dashboard)
GATEWAY_ID=dfrobot
GW_DISPLAY_NAME=DFRobot Gateway
GW_TYPE=dfrobot

# DFRobot ChirpStack credentials
# GW_HOST=10.8.8.8
# GW_EMAIL=admin
# GW_PASS=your-chirpstack-password

# DFRobot SIOT broker credentials
# SIOT_USER=siot
# SIOT_PASS=dfrobot

# ── poller.py — Milesight UG65 gateway (second poller instance) ───────────────
# Run a second copy of poller.py with a DIFFERENT .env file (e.g. .env.ug65)
# pointing at the same DASHBOARD_URL but with these settings instead:
#
# GATEWAY_ID=ug65
# GW_DISPLAY_NAME=Milesight UG65
# GW_TYPE=ug65
# GW_HOST=192.168.1.1
# GW_EMAIL=admin
#
# The UG65's built-in ChirpStack API expects the password as MD5 → base64.
# Compute it with:  python3 -c "import hashlib,base64; print(base64.b64encode(hashlib.md5(b'yourpass').digest()).decode())"
# GW_PASS_HASH=NicJjG18XOV3U1efQyo8AQ==
#
# No SIOT_* vars needed for ug65. Data is delivered via ChirpStack HTTP integration
# (ChirpStack on the UG65 will POST uplinks to DASHBOARD_URL/ingest/lorawan_uplink).
